# ─── Anthropic ────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Supabase ─────────────────────────────────────────────────
# Get from: https://app.supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # NOT the anon key

# ─── Resend (email) ───────────────────────────────────────────
# Get from: https://resend.com/api-keys
# Also: verify your domain at resend.com/domains (add DNS records)
# Then update the "from" address in app/api/email-quote/route.ts
RESEND_API_KEY=re_...

# ─── Vercel (auto-set, no action needed) ──────────────────────
# VERCEL_URL is injected automatically by Vercel on deploy
